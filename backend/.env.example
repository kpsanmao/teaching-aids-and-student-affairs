# =====================================================================
# 学情管理系统 · 环境变量模板（复制为 .env 后按实际修改）
# 参考《学情管理系统开发文档.md》v2.1 · 第 12.3 节
# =====================================================================
APP_NAME="学情管理系统"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://local.ta.lncu.cn
APP_TIMEZONE=Asia/Shanghai

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --------- 日志 ---------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------- 数据库 ---------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=teaching_platform
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_ENGINE=InnoDB

# --------- Session / Cache / Queue ---------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --------- Redis ---------
# 无 ext-redis 时改为 predis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# --------- Broadcasting（Laravel Reverb） ---------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=teaching-platform
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --------- 文件存储（生产建议 s3/MinIO） ---------
FILESYSTEM_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=teaching-platform
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# --------- Sanctum ---------
SANCTUM_STATEFUL_DOMAINS=local.ta.lncu.cn,localhost,127.0.0.1

# --------- Laravel AI SDK ---------
AI_DEFAULT_PROVIDER=anthropic
AI_MODEL_TEXT=claude-sonnet-4-5
AI_MODEL_EMBEDDINGS=text-embedding-3-small

ANTHROPIC_API_KEY=
ANTHROPIC_URL=
OPENAI_API_KEY=
OPENAI_URL=
GEMINI_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434
# Failover 备用 Provider 凭据（可选）
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --------- 报表生成（Puppeteer） ---------
PUPPETEER_ENDPOINT=http://127.0.0.1:3000
PUPPETEER_INTERNAL_BASE_URL=http://local.ta.lncu.cn/internal

# --------- 邮件 ---------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@ta.lncu.cn"
MAIL_FROM_NAME="${APP_NAME}"

# --------- 前端（Vite） ---------
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://local.ta.lncu.cn/api
