# Vite dev server 将 /api /sanctum /broadcasting 代理到这里
# 本地使用 php artisan serve 时走 127.0.0.1:8000；如走 phpStudy Nginx，改为 http://local.ta.lncu.cn
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

VITE_API_BASE=/api

# Laravel Reverb / Pusher 兼容协议
VITE_REVERB_APP_KEY=teaching-platform-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
